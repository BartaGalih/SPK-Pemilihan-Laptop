<mxfile host="app.diagrams.net" type="device">
  <diagram name="Sitemap SPK Rekomendasi Laptop" id="sitemap-spk-laptop">
    <mxGraphModel dx="1300" dy="850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Root -->
        <mxCell id="root" value="SPK Rekomendasi Laptop&#10;(Beranda /)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D47A1;fontColor=#FFFFFF;fontStyle=1;fontSize=16;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="40" width="300" height="64" as="geometry"/>
        </mxCell>

        <!-- Menu level -->
        <mxCell id="m1" value="Data Laptop&#10;/laptops" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565C0;fontColor=#FFFFFF;fontStyle=1;fontSize=15;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="280" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="Kriteria &amp; Bobot&#10;/criteria" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;fontColor=#FFFFFF;fontStyle=1;fontSize=15;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
