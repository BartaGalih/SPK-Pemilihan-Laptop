        <mxCell id="m2c" value="Aksi: Hapus Kriteria&#10;DELETE (soft delete)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#FFE082;fontColor=#000000;fontStyle=2;fontSize=15;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
