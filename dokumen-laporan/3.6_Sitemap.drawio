        <mxCell id="m3" value="Hasil Rekomendasi&#10;/results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E65100;fontColor=#FFFFFF;fontStyle=1;fontSize=15;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="800" y="220" width="280" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="m4" value="Arsip Hasil&#10;/snapshots" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4A148C;fontColor=#FFFFFF;fontStyle=1;fontSize=15;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1170" y="220" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- Data Laptop children -->
        <mxCell id="m1a" value="Tambah Laptop&#10;/laptops/create" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontColor=#000000;fontSize=15;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="240" height="52" as="geometry"/>
        </mxCell>
        <mxCell id="m1b" value="Detail Laptop&#10;/laptops/{id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontColor=#000000;fontSize=15;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="432" width="240" height="52" as="geometry"/>
