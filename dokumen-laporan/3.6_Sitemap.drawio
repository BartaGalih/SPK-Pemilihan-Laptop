          <mxGeometry x="80" y="504" width="240" height="52" as="geometry"/>
        </mxCell>
        <mxCell id="m1d" value="Aksi: Hapus Laptop&#10;DELETE /laptops/{id}" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#FFE082;fontColor=#000000;fontStyle=2;fontSize=15;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="576" width="240" height="52" as="geometry"/>
